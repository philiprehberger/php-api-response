{
    "name": "philiprehberger/php-api-response",
    "description": "Standardized API response builder for consistent JSON APIs",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "keywords": [
        "api",
        "response",
        "json",
        "rest",
        "standardized"
    ],
    "authors": [
        {
            "name": "Philip Rehberger"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel response macros (^11.0|^12.0)"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\ApiResponse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\ApiResponse\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
